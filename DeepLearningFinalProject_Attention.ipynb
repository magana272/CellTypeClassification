        "    print(f'{epoch:>6} | {tr_loss:>10.4f} | {tr_acc:>8.4f} | {vl_loss:>9.4f} | {vl_acc:>8.4f}{flag}')\n",
        "\n",
        "    if no_improve >= patience:\n",
        "        print(f'\\nEarly stopping at epoch {epoch}.')\n",
        "        break\n",
        "\n",
        "print(f'\\nBest val accuracy: {best_val_acc:.4f}')\n",
        "\n",
